<div class="page-head">
  <a class="back" href="/actividad">← Volver a la actividad</a>
  <h1>Mi actividad</h1>
  <p>Rellena cada apartado a tu ritmo. Cada bloque se guarda por separado.</p>
</div>

<% if (sub && sub.status && sub.status !== 'pendiente') { %>
  <div class="eval-banner eval-<%= sub.status %>">
    <div>
      <span class="eval-status"><%= subStatus[sub.status] %></span>
      <% if (sub.feedback) { %><div class="eval-feedback rich-text"><%- sub.feedback %></div><% } %>
    </div>
  </div>
<% } %>

<div class="submit-panel <%= sub && sub.submitted ? 'is-done' : '' %>">
  <div>
    <% if (sub && sub.submitted) { %>
      <strong>✓ Entrega finalizada</strong>
      <span class="meta"><%= sub.submitted_at ? 'el ' + fmtDate(sub.submitted_at) : '' %> · avisa a la organización si necesitas reabrirla.</span>
    <% } else { %>
      <strong>Entrega en curso</strong>
      <span class="meta">Cuando la tengas lista, márcala como finalizada para que la revisen.</span>
    <% } %>
  </div>
  <div class="submit-actions">
    <a class="btn btn-ghost btn-sm" href="/actividad/u/<%= currentUser.id %>/imprimir" target="_blank">⬇ Guardar en PDF</a>
    <form action="/actividad/finalizar" method="post">
      <button class="btn <%= sub && sub.submitted ? 'btn-ghost' : 'btn-primary' %> btn-sm" type="submit">
        <%= sub && sub.submitted ? 'Reabrir' : 'Marcar como finalizada' %>
      </button>
    </form>
  </div>
</div>

<form action="/actividad/titulo" method="post" class="form title-form">
  <label>Título de tu tarea <span class="hint">(la asignatura y la tarea que rediseñas)</span>
    <div class="inline">
      <input type="text" name="task_title" value="<%= sub && sub.task_title ? sub.task_title : '' %>" placeholder="p. ej. Comentario de texto · Historia 4º ESO">
      <button class="btn btn-primary btn-sm" type="submit">Guardar</button>
    </div>
  </label>
</form>

<% activityParts.forEach(function(p, i){ %>
  <section class="activity-part" id="<%= p.key %>">
    <div class="part-head">
      <span class="step-n"><%= i + 1 %></span>
      <div>
        <h2><%= p.label %></h2>
        <span class="step-tag"><%= p.tag %></span>
      </div>
    </div>
    <p class="step-help"><%= p.help %></p>

    <form action="/actividad/texto" method="post" class="form">
      <input type="hidden" name="part" value="<%= p.key %>">
      <div class="rte">
        <div class="rte-toolbar">
          <button type="button" data-cmd="bold" title="Negrita"><b>B</b></button>
          <button type="button" data-cmd="italic" title="Cursiva"><i>I</i></button>
          <button type="button" data-cmd="underline" title="Subrayado"><span style="text-decoration:underline">U</span></button>
          <button type="button" data-cmd="insertUnorderedList" title="Lista con viñetas">•&nbsp;Lista</button>
          <button type="button" data-cmd="insertOrderedList" title="Lista numerada">1.&nbsp;Lista</button>
        </div>
        <div class="rte-area" contenteditable="true" data-placeholder="Escribe aquí… (puedes pegar desde Word y conserva el formato)"><%- texts[p.key] || '' %></div>
        <input type="hidden" name="body" value="">
      </div>
      <button class="btn btn-primary btn-sm" type="submit">Guardar apartado</button>
    </form>

    <% var files = filesByPart[p.key] || []; %>
    <% if (files.length) { %>
      <ul class="attach-list">
        <% files.forEach(function(f){ %>
          <li class="attach">
            <div class="attach-body">
              <% if (f.title) { %><strong><%= f.title %></strong><% } %>
              <%- include('partials/filechips', { item: f, viewerBase: '/actividad/archivo' }) %>
            </div>
            <form action="/actividad/archivo/<%= f.id %>/delete" method="post" onsubmit="return confirm('¿Eliminar este adjunto?')">
              <button class="link-btn danger">Eliminar</button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <details class="composer">
      <summary>+ Añadir archivo o enlace</summary>
      <form action="/actividad/archivo" method="post" enctype="multipart/form-data" class="form">
        <input type="hidden" name="part" value="<%= p.key %>">
        <label>Título <span class="hint">(opcional)</span>
          <input type="text" name="title" placeholder="p. ej. Captura de la respuesta de la IA">
        </label>
        <div class="row">
          <label>Enlace <span class="hint">(web, o Google Slides/Drive)</span>
            <input type="text" name="url" placeholder="https://… o enlace de Google">
          </label>
          <label>Archivo <span class="hint">(PDF, PPTX, imagen…)</span>
            <input type="file" name="file" accept=".pdf,.ppt,.pptx,.doc,.docx,.jpg,.jpeg,.png">
          </label>
        </div>
        <button class="btn btn-primary btn-sm" type="submit">Añadir</button>
      </form>
    </details>
  </section>
<% }) %>

<script src="/public/editor.js"></script>
