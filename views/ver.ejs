<div class="viewer-head">
  <a class="back" href="<%= backUrl %>">← <%= backLabel %></a>
  <h1><%= item.title %></h1>
  <% if (item.description) { %><p class="viewer-desc"><%= item.description %></p><% } %>
</div>

<% if (item.file_kind === 'pdf') { %>
  <div class="viewer-actions">
    <a class="btn btn-ghost btn-sm" href="/uploads/<%= item.file_path %>" download="<%= item.file_name %>">⬇ Descargar PDF</a>
  </div>
  <iframe class="pdf-frame" src="/uploads/<%= item.file_path %>" title="<%= item.title %>"></iframe>

<% } else if (item.file_kind === 'embed') { %>
  <% var embedSrc = String(item.embed_url || '').replace(/[?&]rm=minimal/, ''); %>
  <div class="embed-controls">
    <button type="button" class="btn btn-primary btn-sm" id="fs-btn">⛶ Pantalla completa</button>
    <span class="viewer-note">Usa las flechas ◀ ▶ del reproductor para pasar de diapositiva.</span>
  </div>
  <div class="embed-wrap" id="embed-wrap">
    <iframe class="embed-frame" src="<%= embedSrc %>" title="<%= item.title %>" allowfullscreen allow="fullscreen"></iframe>
  </div>
  <script>
    (function () {
      var btn = document.getElementById('fs-btn');
      var wrap = document.getElementById('embed-wrap');
      if (!btn || !wrap) return;
      btn.addEventListener('click', function () {
        var el = wrap;
        if (el.requestFullscreen) el.requestFullscreen();
        else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
      });
    })();
  </script>

<% } else if (item.file_kind === 'slides') { %>
  <% if (slides.length === 0) { %>
    <p class="empty big">No se han encontrado diapositivas para esta presentación.</p>
  <% } else { %>
    <p class="viewer-note">Presentación de <%= slides.length %> diapositivas · solo consulta</p>
    <div class="slides">
      <% slides.forEach(function(s, i){ %>
        <figure class="slide">
          <img src="/uploads/<%= item.file_path %>/<%= s %>" alt="Diapositiva <%= i + 1 %>" loading="lazy">
          <figcaption><%= i + 1 %> / <%= slides.length %></figcaption>
        </figure>
      <% }) %>
    </div>
  <% } %>
<% } %>
